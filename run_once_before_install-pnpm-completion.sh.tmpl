#!/bin/sh
# Generate pnpm's tabtab-based zsh completion files into ~/.config/tabtab/zsh/.
# Runs only once per machine (run_once_) and before file targets (before_) so
# that the chezmoi-managed .zshrc, applied right after, overrides the spurious
# completion block that `pnpm install-completion` appends to ~/.zshrc.

set -e

# Find pnpm at canonical paths if not on PATH (mirrors install-packages.sh).
if command -v pnpm >/dev/null 2>&1; then
  PNPM=pnpm
elif [ -x /opt/homebrew/bin/pnpm ]; then
  PNPM=/opt/homebrew/bin/pnpm
elif [ -x /usr/local/bin/pnpm ]; then
  PNPM=/usr/local/bin/pnpm
else
  echo "pnpm not found; skipping completion install." >&2
  exit 0
fi

"$PNPM" install-completion zsh
