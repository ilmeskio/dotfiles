#!/bin/sh
# Install/update Homebrew packages from the Brewfile.
# Hash below ties this script's identity to the Brewfile content so chezmoi reruns it on change:
# Brewfile sha256: {{ include "Brewfile" | sha256sum }}

set -e

# Find brew even when it isn't on PATH yet (common on a fresh machine where
# the user installed Homebrew but hasn't run `eval $(brew shellenv)` in this
# shell). Falls back to the canonical install paths for Apple Silicon and
# Intel before giving up.
if command -v brew >/dev/null 2>&1; then
  BREW=brew
elif [ -x /opt/homebrew/bin/brew ]; then
  BREW=/opt/homebrew/bin/brew
elif [ -x /usr/local/bin/brew ]; then
  BREW=/usr/local/bin/brew
else
  echo "Homebrew not found. Install it from https://brew.sh and re-run 'chezmoi apply'." >&2
  exit 1
fi

"$BREW" bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
