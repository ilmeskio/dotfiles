#!/bin/sh
# ABOUTME: Reloads the 1Password SSH agent LaunchAgent (unload+load) whenever its plist changes
# ABOUTME: Hash below ties this script's identity to the plist so chezmoi sees the onchange:
# plist sha256: {{ include "private_Library/LaunchAgents/com.1password.SSH_AUTH_SOCK.plist" | sha256sum }}

set -e
PLIST="$HOME/Library/LaunchAgents/com.1password.SSH_AUTH_SOCK.plist"
launchctl unload "$PLIST" 2>/dev/null || true
launchctl load "$PLIST"
