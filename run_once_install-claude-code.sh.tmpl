#!/bin/sh
# ABOUTME: First-install of the Claude Code CLI via Anthropic's native installer
# ABOUTME: Runs once per machine; subsequent updates handled by `claude update`, not chezmoi
#
# The installer drops the binary into ~/.local/share/claude/versions/<version>
# and symlinks it to ~/.local/bin/claude.

set -e

if command -v claude >/dev/null 2>&1; then
  echo "claude already installed at $(command -v claude); skipping."
  exit 0
fi

echo "Installing Claude Code..."
curl -fsSL https://claude.ai/install.sh | bash
