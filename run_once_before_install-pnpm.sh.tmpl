#!/bin/sh
# Install pnpm (standalone, self-contained build with embedded Node) and
# generate its zsh completion script.
#
# Why the standalone build instead of `brew install pnpm`: the Homebrew
# formula ships pnpm as a `#!/usr/bin/env node` script and therefore needs
# a system Node binary at runtime — which this setup deliberately doesn't
# install (Node is per-project via fnm). The standalone build embeds Node,
# so it works on a Node-less machine.
#
# The pnpm installer appends PATH lines to ~/.zshrc; those are overwritten
# by the chezmoi-managed dot_zshrc applied right after this script.

set -e

PNPM_HOME="${PNPM_HOME:-$HOME/Library/pnpm}"
export PNPM_HOME

if [ ! -x "$PNPM_HOME/pnpm" ] && ! command -v pnpm >/dev/null 2>&1; then
  echo "Installing pnpm (standalone)..."
  curl -fsSL https://get.pnpm.io/install.sh | sh -
fi

if command -v pnpm >/dev/null 2>&1; then
  PNPM=pnpm
elif [ -x "$PNPM_HOME/pnpm" ]; then
  PNPM="$PNPM_HOME/pnpm"
else
  echo "pnpm not found after install; aborting." >&2
  exit 1
fi

# `pnpm completion zsh` prints the completion script on stdout. We write it
# to ~/.config/pnpm/zsh-completion.zsh and source it from dot_zshrc.
echo "Generating pnpm zsh completion..."
mkdir -p "$HOME/.config/pnpm"
"$PNPM" completion zsh > "$HOME/.config/pnpm/zsh-completion.zsh"
